# ── LLM Provider ──────────────────────────────────────────────────────────────
# Select one provider: openai | ollama | gptec
LLM_PROVIDER=openai

# ── Option 1: OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o-mini

# ── Option 2: Ollama (local) ──────────────────────────────────────────────────
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Option 3: GPTec (OpenAI-compatible custom endpoint) ───────────────────────
# LLM_PROVIDER=gptec
# GPTEC_API_URL=https://<your-gptec-endpoint>/v1
# GPTEC_API_KEY=<your-gptec-api-key>
# GPTEC_MODEL=<model-name>

# ── Approval & KPI Thresholds ────────────────────────────────────────────────
APPROVAL_BULK_THRESHOLD=100
APPROVAL_CAMPAIGN_REACH_THRESHOLD=1000
APPROVAL_RISK_SCORE_THRESHOLD=0.8
APPROVAL_PAYMENT_DELAY_THRESHOLD=0.8
KPI_DEVIATION_THRESHOLD=0.10
TARGET_CONVERSION_RATE=0.05
SQL_MAX_ROWS=10000
GUARDRAIL_ENABLED=true

# ── Infrastructure ────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/customers.db
CHROMA_PERSIST_DIR=data/chroma
AUDIT_LOG_PATH=data/audit.jsonl
OUTCOMES_PATH=data/campaign_outcomes.jsonl
CHART_OUTPUT_DIR=data/charts

# ── Observability (optional) ──────────────────────────────────────────────────
# Self-hosted Langfuse (docker compose up in the langfuse repo)
# LANGFUSE_PUBLIC_KEY=<your-langfuse-public-key>
# LANGFUSE_SECRET_KEY=<your-langfuse-secret-key>
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PROJECT=agenticAI
# OBSERVABILITY_VERBOSE=1
